from urllib.error import HTTPError
from n5core.pick import pickUnlessOne
from pypdf import PdfReader

class infoReader():
    def __init__(self, fh, filepath):
        self.title = None
        self.filename = os.path.basename(filepath)
    def getTitle(self): return self.title
    def getFilename(self): return self.filename

class pdfReader(infoReader):
    def __init__(self, fh, filepath):
        """
Extract document information from PDF.  Must read every value in the
constructor, to avoid moving the file handle pointer for others later.
"""
        infoReader.__init__(self, fh, filepath)
        reader = PdfReader(fh)
        metadata = reader.metadata
        self.title = getattr(metadata, '/Title', None) or None
        self.producer = getattr(metadata, '/Producer', None) or None
        self.creator = getattr(metadata, '/Creator', None) or None
        # Detect PDF version from header like "%PDF-1.5"
        hdr = reader.pdf_header  # e.g. "%PDF-1.5"
        ver = hdr.split('-')[1] if '-' in hdr else ''
        if ver in pdf_formatcodes:
            self.format = {'kode': pdf_formatcodes[ver]}
        else:
            self.format = None

class imageReader(infoReader):
    def __init__(self, fh, filepath):
        infoReader.__init__(self, fh, filepath)
        return

class rfc822Reader(infoReader):
    def __init__(self, fh, filepath):
        infoReader.__init__(self, fh, filepath)
        self.filename = None
        fh.seek(0, os.SEEK_SET)
        msg = email.message_from_file(fh)
        if 'subject' in msg:
            subject, encoding = \
                email.Header.decode_header(msg.get('subject'))[0]
            if encoding!=None:
                self.title = subject.decode(encoding)
            print("S: %s" % self.title)
        if 'message-id' in msg:
            self.filename = msg['message-id']
        return

# PRONOM codes for PDF versions (from https://www.nationalarchives.gov.uk/PRONOM/)
pdf_formatcodes = {
    '1.2': 'fmt/16',   # PDF (1.2)
    '1.3': 'fmt/17',   # PDF (1.3)
    '1.4': 'fmt/18',   # PDF (1.4)
    '1.5': 'fmt/19',   # PDF (1.5)
    '1.6': 'fmt/20',   # ISO 32000-1:2008
    '1.7': 'fmt/276',  # Acrobat PDF 1.7
}

# Mapping from magic string to Noark 5 format info
# Based on the spec list of formats on page 173.
formatlist = {
    # PDF/A - ISO 19005 1:205
    'application/pdf': {
        'inforeader': pdfReader,
        },
    # JPEG (ISO 10918-1:1994)
    'image/jpeg': {
        'inforeader': imageReader,
        'format':     { 'kode': 'fmt/42' },
    },
    # TIFF versjon 6
    'image/tiff': {
        'inforeader': imageReader,
        'format':     { 'kode': 'fmt/353' },
    },
    # Ren text
    # XML v1
    # SOSI v2.2 (1995 el. nyere)
    # MPEG-2 (ISO 13818-2)
    # MP3 (ISO 11172-3 PCM eller PCM-basert)

    # Unofficial types:
    'message/rfc822': {
        'inforeader': rfc822Reader,
        'format':     { 'kode': 'fmt/278' },
    },
}

def objectOperation(json, relation):
    """
Return the URL/href for a given relation on the object represented by
the json structure.  If the link is templated, strip OData query params.

"""
    if json is None or '_links' not in json:
        return None
    if relation in json['_links']:
        href = json['_links'][relation]['href']
        if json['_links'][relation].get('templated', False):
            href = href.split('{')[0]
        return href
    return None

def createObject(api, url, data):
    try:
        (c, res) = api.json_post(url, data)
    except HTTPError as e:
        body = e.read().decode('UTF-8', errors='replace')
        print("error: POST to %s failed with HTTP %d:" % (url, e.code), file=sys.stderr)
        try:
            jbody = json.loads(body)
            if 'feil' in jbody and 'beskrivelse' in jbody['feil']:
                print("  %s" % jbody['feil']['beskrivelse'], file=sys.stderr)
            else:
                print("  %s" % body, file=sys.stderr)
        except (json.JSONDecodeError, KeyError):
            print("  %s" % body, file=sys.stderr)
        raise
    fondinfo = json.loads(c)
    return fondinfo

def getFileSize(filehandle):
    curpos = filehandle.tell()
    filehandle.seek(0, os.SEEK_END)
    size = filehandle.tell()
    filehandle.seek(curpos, os.SEEK_SET)
    return size

def main():
    relbase = 'https://rel.arkivverket.no/noark5/v5/api'
    baseurl = "https://localhost:8092/noark5v5/"
    parser = argparse.ArgumentParser()
    parser.add_argument("--baseurl", help="(default is %s)" % baseurl)
    parser.add_argument("--username", help="login username")
    parser.add_argument("--password", help="login password")
    parser.add_argument("--storageurl", help="URL of the mappe or registrering to store files under (bypasses interactive selection)")
    parser.add_argument("--verbose", help="print more debug information",
                        action="store_true")
    parser.add_argument("filename", nargs='+', help="file to archive")
    args = parser.parse_args()

    if args.baseurl:
        baseurl = args.baseurl

    retval = 0
    api = n5core.endpoint.Endpoint(baseurl)
    api.verbose = args.verbose
    api.login(username=args.username, password=args.password)

    fileinfo = None
    if args.storageurl:
        (c, res) = api.json_get(args.storageurl)
        storageinfo = json.loads(c)
        # If the URL is a collection, pick the first item; otherwise use it directly
        if '_links' in storageinfo and 'self' in storageinfo['_links']:
            fileinfo = storageinfo
        elif isinstance(storageinfo.get('results'), list):
            results = storageinfo['results']
            if len(results) == 1:
                fileinfo = results[0]
            else:
                print("error: Collection contains %d items, expected 1. Use a single entity URL." % len(results))
                return
        else:
            fileinfo = storageinfo
    else:
        fondsrel = relbase + '/arkivstruktur/arkiv/'
        fondshref = api.findRelation(fondsrel)

        (c, res) = api.json_get(fondshref)
        fondsinfo = json.loads(c)
        info = pickUnlessOne(fondsinfo, 'arkiv')
        if info is None:
            print("error: Fant intet relasjon for %s.  Tom database?" % fondsrel)
            print("error: Kan ikke laste opp dokumenter uten definert arkiv.")
            return

        seriesrel = relbase + '/arkivstruktur/arkivdel/'
        serieshref = objectOperation(info, seriesrel)
        if serieshref is None:
            print("error: Fant ingen relasjon for %s.  Tom database?" % seriesrel)
            print("error: Kan ikke laste opp dokumenter uten definert arkivdel.")
            return
        (c, res) = api.json_get(serieshref)
        seriesinfo = json.loads(c)
        info = pickUnlessOne(seriesinfo, 'arkivdel')
        if info is None:
            print("error: Fant ingen arkivdel.  Tom database?")
            print("error: Kan ikke laste opp dokumenter uten definert arkivdel.")
            return

        filesrel = relbase + '/arkivstruktur/mappe/'

        def findLeafMappe(mappe_list_info, depth=0):
            """Recursively find a leaf mappe (one without undermappe children)."""
            for cand in mappe_list_info.get('results', []):
                undermappe_rel = relbase + '/arkivstruktur/undermappe/'
                under_href = objectOperation(cand, undermappe_rel)
                if not under_href:
                    return cand  # no undermappe relation at all
                (uc, ur) = api.json_get(under_href)
                udata = json.loads(uc)
                if len(udata.get('results', [])) == 0:
                    return cand  # leaf mappe found
                if depth < 10:
                    child = findLeafMappe(udata, depth + 1)
                    if child:
                        return child
            return None

        def getMappesFromEntity(entity):
            """Get the list of mapper from an entity (arkivdel, klasse, etc.)."""
            fileshref = objectOperation(entity, filesrel)
            if fileshref is None:
                return None
            (c, res) = api.json_get(fileshref)
            return json.loads(c)

        def pickLeafMappe(mappe_list_info):
            """Pick a mappe from list, auto-drilling to leaf if needed."""
            fileinfo = pickUnlessOne(mappe_list_info, 'mappe', quiet=True)
            if fileinfo is None:
                print("error: Fant ingen mappe.  Tom database?")
                return None

            # Skip mapper that have child mapper (Nikita rejects uploads into such mapper)
            undermappe_rel = relbase + '/arkivstruktur/undermappe/'
            under_href = objectOperation(fileinfo, undermappe_rel)
            if under_href:
                (uc, ur) = api.json_get(under_href)
                udata = json.loads(uc)
                if len(udata.get('results', [])) > 0:
                    print("warning: Selected mappe has child mapper, finding a leaf mappe...")
                    fileinfo = findLeafMappe(mappe_list_info)
                    if fileinfo is None:
                        print("error: No suitable leaf mappe found.")
                        return None

            href = fileinfo['_links']['self']['href']
            label = fileinfo.get('tittel', fileinfo['systemID'])
            print("using mappe: %s (%s)" % (label, href))
            return fileinfo

        # Check for klassifikasjonssystem path first (arkivdel->klassif->klasse->mappe)
        ksrel = relbase + '/arkivstruktur/klassifikasjonssystem/'
        kshref = objectOperation(info, ksrel)
        if kshref:
            (c, res) = api.json_get(kshref)
            ksinfo = json.loads(c)
            if len(ksinfo.get('results', [])) > 0:
                print("Found klassifikasjonssystem under arkivdel, drilling down...")

                ksys = pickUnlessOne(ksinfo, 'klassifikasjonssystem')
                if ksys is None:
                    print("error: No klassifikasjonssystem available.")
                    return

                # klasse under klassifikasjonssystem
                kelasrel = relbase + '/arkivstruktur/klasse/'
                kelashref = objectOperation(ksys, kelasrel)
                if kelashref:
                    (c, res) = api.json_get(kelashref)
                    kelasinfo = json.loads(c)
                    if len(kelasinfo.get('results', [])) > 0:
                        klasse = pickUnlessOne(kelasinfo, 'klasse')
                        if klasse is None:
                            print("error: No klasse available.")
                            return

                        # Check for underklasse (sub-classes)
                        underkelasrel = relbase + '/arkivstruktur/underklasse/'
                        underkashref = objectOperation(klasse, underkelasrel)
                        if underkashref:
                            (c, res) = api.json_get(underkashref)
                            ukinfo = json.loads(c)
                            if len(ukinfo.get('results', [])) > 0:
                                uklasse = pickUnlessOne(ukinfo, 'underklasse')
                                if uklasse is not None:
                                    klasse = uklasse

                        # mappe under (sub-)klasse
                        mappe_list = getMappesFromEntity(klasse)
                        fileinfo = pickLeafMappe(mappe_list)
                        if fileinfo is None:
                            return

                    # If no classes, fall through to direct mappe check below
                if not kelashref or len(kelasinfo.get('results', [])) == 0:
                    pass  # fall through to direct mappe path

        # Direct mappe under arkivdel (fallback / primary when no klassifikasjonssystem)
        if fileinfo is None:
            mappe_list = getMappesFromEntity(info)
            if mappe_list is None:
                print("error: Fant intet relasjon for %s.  Tom database?" % filesrel)
                print("error: Kan ikke laste opp dokumenter uten definert mappe.")
                return

            fileinfo = pickLeafMappe(mappe_list)
            if fileinfo is None:
                return

    # Test if it is possible to reach a dokumentobject by following
    # the relations from the top.
    if False:
        fileshref = objectOperation(fileinfo, relbase + '/arkivstruktur/registrering/')
        #print("Registrering %s" % fileshref)
        (c, res) = api.json_get(fileshref)
        filesinfo = json.loads(c)
        reginfo = pickUnlessOne(filesinfo, 'registrering')

        fileshref = objectOperation(reginfo, relbase + '/arkivstruktur/dokumentbeskrivelse/')
        #print("Dokumentbeskrivelse %s" % fileshref)
        (c, res) = api.json_get(fileshref)
        filesinfo = json.loads(c)
        docdescinfo = pickUnlessOne(filesinfo, 'dokumentbeskrivelse')

        fileshref = objectOperation(docdescinfo, relbase + '/arkivstruktur/dokumentobjekt/')
        #print("Dokumentobjekt %s" % fileshref)
        (c, res) = api.json_get(fileshref)
        filesinfo = json.loads(c)
        docobjinfo = pickUnlessOne(filesinfo, 'dokumentobjekt')

    #
    # Correct file located, add record, document description and
    # document object for each file.
    #
    for filename in (args.filename):
        format = None
        mimetype = None
        inforeader = None
        fh = open(filename, "rb")

        hashalg = "SHA-256"
        hasher = sha256()
        for chunk in iter(lambda: fh.read(8192), b''): 
            hasher.update(chunk)
        hash = hasher.hexdigest()

        mimetype = magic.from_file(filename, mime=True)
        if mimetype in formatlist:
            inforeader = formatlist[mimetype]['inforeader']
            if 'format' in formatlist[mimetype]:
                format = formatlist[mimetype]['format']
        else:
            inforeader = infoReader
        if mimetype is None:
            print("error: Unknown mime type '%s', skipping" % mimetype)
            continue
        
        filesize = getFileSize(fh)
        r = inforeader(fh, filename)
        doctitle = r.getTitle()
        basename = r.getFilename()
        if doctitle is None or '' == doctitle:
            doctitle = basename
        variantformatcode = 'A'
        variantformat = "Arkivformat"
        fh.seek(0, os.SEEK_SET)

        print("Uploading %s\n  Document title: %s\n  File %s: %s" % \
              (filename, doctitle, fileinfo['systemID'], fileinfo['tittel']))
        
        newreghref = objectOperation(fileinfo, relbase + '/arkivstruktur/ny-registrering/')
        recordinfo = createObject(api, newreghref, { 'tittel': doctitle })

        # adding documentbeskrivelse between registrering av
        # dokumentobject might be optional, but skipping it is not
        # implemented by Nikita 2017-03-22.  Once it is implemented,
        # consier replacing 'docdescifo' with 'recordinfo' in the
        # ny-dokumentobject call to objectOperation().
        newdocdeschref = objectOperation(recordinfo,
                                         relbase + '/arkivstruktur/ny-dokumentbeskrivelse/')
        docdescinfo = createObject(api, newdocdeschref, {
            'tittel' : doctitle,
            'dokumenttype': {
                'kode': 'B',
                'kodenavn': 'Brev'
            },
            'dokumentstatus': {
                'kode': 'F',
                'kodenavn': 'Dokumentet er ferdigstilt'
            },
#            'dokumentnummer': str(1),
            'tilknyttetRegistreringSom': {
                'kode': 'H',
                'kodenavn': 'Hoveddokument'
            },
        })

        newdocobjhref = objectOperation(docdescinfo,
                                        relbase + '/arkivstruktur/ny-dokumentobjekt/')
        data = {
            "versjonsnummer" : 0,
            "variantformat"  : {
                'kode': variantformatcode,
                'kodenavn': variantformat,
            },
            "mimeType"       : mimetype,
            "filstoerrelse"  : filesize,
            "filnavn"        : basename,
            "sjekksum"       : hash,
            "sjekksumAlgoritme" : hashalg,
        }
        fmt = getattr(r, 'format', None) or format
        if fmt:
            data['format'] = fmt
        docobjinfo = createObject(api, newdocobjhref, data)

        newfilehref = objectOperation(docobjinfo, relbase + '/arkivstruktur/fil/')
        try:
            (c, res) = api.post(newfilehref, fh, mimetype, length=filesize)
        except HTTPError as e:
            body = e.read().decode('UTF-8', errors='replace')
            print("error: file upload to %s failed with HTTP %d:" % (newfilehref, e.code), file=sys.stderr)
            try:
                jbody = json.loads(body)
                if 'feil' in jbody and 'beskrivelse' in jbody['feil']:
                    print("  %s" % jbody['feil']['beskrivelse'], file=sys.stderr)
                else:
                    print("  %s" % body, file=sys.stderr)
            except (json.JSONDecodeError, KeyError):
                print("  %s" % body, file=sys.stderr)
            retval = 1
            continue
        if 201 != res.code:
            print("error: upload failed (status == %d)" % res.code)
            retval = 1
    return retval

if __name__ == '__main__':
    exit(main())
